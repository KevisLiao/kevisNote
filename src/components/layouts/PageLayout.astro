---
import HeadMeta from './HeadMeta.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import NormalJsonLd from '@/components/json-ld/normal.astro';
import slateConfig from '~@/slate.config';
import { getFullTitle } from '@/helpers/utils';
import { localeMeta, getTranslations } from '@/i18n';
import type { LocaleCode } from '@/typings/config';
import '@/assets/style/common.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  locale?: LocaleCode;
}

const {
  title = '',
  description,
  image = '/og_image.png',
  locale = (Astro.currentLocale as LocaleCode) ?? slateConfig.i18n.defaultLocale,
} = Astro.props;
// Fall back to the locale-specific site tagline when no page description is given.
const resolvedDescription = description ?? getTranslations(locale)('site.description');
const fullTitle = getFullTitle(title);
const htmlLang = localeMeta[locale]?.htmlLang ?? locale;

// hreflang alternates: same path with each locale's prefix swapped in.
const restPath = Astro.url.pathname.replace(/^\/[^/]+/, '');
const alternates = slateConfig.i18n.locales.map((code) => ({
  hreflang: localeMeta[code]?.htmlLang ?? code,
  href: new URL(`/${code}${restPath}`, Astro.site).href,
}));
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// remark: Temporary solution to refresh theme flicker issue
const themeScript = `
  function getThemeMode() {
    const theme = localStorage.getItem('theme');
    if (theme && (theme === 'light' || theme === 'dark')) return theme;

    const presetTheme = theme === 'auto' ? theme : '${slateConfig.theme?.mode}';
    if (presetTheme === 'auto')
      return window.matchMedia('(prefers-color-scheme: dark)').matches
        ? 'dark'
        : 'light';

    return presetTheme;
  }
  const mode = getThemeMode();
  document.documentElement.className = mode;
  document.documentElement.dataset.theme = mode;
`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <HeadMeta
      title={fullTitle}
      description={resolvedDescription}
      image={image}
      locale={locale}
      canonical={canonical}
      alternates={alternates}
    />
    <slot name="json-ld">
      <NormalJsonLd title={fullTitle} description={resolvedDescription} image={image} />
    </slot>
    <script set:html={themeScript}></script>
  </head>
  <body class="bg-slate1">
    <div class="m-auto flex min-h-dvh max-w-180 flex-col px-6 pb-6 pt-18">
      <slot name="header">
        <Header locale={locale} />
      </slot>
      <slot />
      <slot name="footer">
        <Footer />
      </slot>
    </div>
  </body>
</html>
