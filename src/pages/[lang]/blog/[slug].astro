---
import dayjs from 'dayjs';
import { render } from 'astro:content';
import { getTranslations } from '@/i18n';
import PageLayout from '@/components/layouts/PageLayout.astro';
import ArticleJsonLd from '@/components/json-ld/article.astro';
import Button from '@/components/button';
import AffixTitle from '@/components/affix-title';
import Share from '@/components/share';
import Toc from '@/components/toc';
import CodeGroupEvent from '@/components/code-group-event';
import slateConfig from '~@/slate.config';
import { getFullTitle } from '@/helpers/utils';
import { getPostPaths, type ResolvedPost } from '@/helpers/posts';
import 'remark-block-containers/css';
import '@/assets/style/blog.css';

export async function getStaticPaths() {
  return getPostPaths();
}

type Props = ResolvedPost;

const { entry, locale, isAuto } = Astro.props as Props;
const t = getTranslations(locale);
const { Content, remarkPluginFrontmatter, headings } = await render(entry);

const lastModifiedDate = dayjs(
  remarkPluginFrontmatter.lastModified
    ? remarkPluginFrontmatter.lastModified
    : undefined,
);
const lastModified = lastModifiedDate.isSame(dayjs(), 'year')
  ? lastModifiedDate.format('MMM DD')
  : lastModifiedDate.format('MMM DD, YYYY');
const pubDate = dayjs(entry.data.pubDate);
const formattedPubDate = pubDate.isSame(dayjs(), 'year')
  ? pubDate.format('MMM DD')
  : pubDate.format('MMM DD, YYYY');
const homeHref = `/${locale}/`;

const shareLabels = {
  label: t('blog.share.label'),
  copyLink: t('blog.share.copyLink'),
  copied: t('blog.share.copied'),
  x: t('blog.share.shareTo', { platform: 'X' }),
  facebook: t('blog.share.shareTo', { platform: 'Facebook' }),
  linkedin: t('blog.share.shareTo', { platform: 'LinkedIn' }),
  threads: t('blog.share.shareTo', { platform: 'Threads' }),
  mail: t('blog.share.shareViaEmail'),
};
---

<PageLayout title={entry.data.title} description={entry.data.description} locale={locale}>
  <ArticleJsonLd
    slot="json-ld"
    title={getFullTitle(entry.data.title)}
    description={entry.data.description}
    pubDate={entry.data.pubDate}
    lastModified={lastModifiedDate.toDate()}
  />
  <CodeGroupEvent client:only="react" />
  <AffixTitle title={entry.data.title} offsetTop={100} client:idle />

  <div class="mb-16" slot="header">
    <Button id="back">←</Button>
  </div>

  <div class="blog-content">
    <div class="mb-16">
      <h1>{entry.data.title}</h1>
      <div class="text-slate10 flex items-center gap-2">
        <span>{formattedPubDate}</span>
        {!!slateConfig.readTime && <span>·</span>}
        {
          slateConfig.readTime && (
            <div>
              {t('blog.readingTime', {
                minutes: remarkPluginFrontmatter.minutesRead,
              })}
            </div>
          )
        }
      </div>
      {
        isAuto && (
          <div class="mt-4 rounded-md bg-slate3 px-3 py-2 text-sm text-slate10">
            {t('blog.aiTranslated')}
          </div>
        )
      }
    </div>
    <Content />
    {
      slateConfig.lastModified && (
        <div class="text-slate8">
          {t('blog.lastModified')} {lastModified}
        </div>
      )
    }
    <Share
      title={entry.data.title}
      url={Astro.url.href}
      labels={shareLabels}
      className="mt-12 border-t border-slate4 pt-6"
      client:idle
    />
  </div>
  <!-- E 内容 -->
  <!-- S 目录 -->
  <Toc
    className="fixed top-0 right-0 bottom-0 hidden w-64 xl:block"
    listClassName="px-5 pt-44 pb-14 "
    dataSource={headings}
    client:visible
  />
  <!-- E 目录 -->
</PageLayout>

<script src="//unpkg.com/heti/umd/heti-addon.min.js" is:inline></script>
<script is:inline define:vars={{ homeHref }}>
  const backBtn = document.getElementById('back');
  backBtn?.addEventListener('click', () => {
    window.location.href = homeHref;
  });

  const heti = new Heti('.blog-content');
  heti.autoSpacing();
</script>
