---
import Search from '@/components/search';
import PageLayout from '@/components/layouts/PageLayout.astro';
import slateConfig from '~@/slate.config';
import { localeMeta } from '@/i18n';
import { getLocalizedPosts, i18nConfig } from '@/helpers/posts';
import type { LocaleCode } from '@/typings/config';

export async function getStaticPaths() {
  return i18nConfig.locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as LocaleCode;
const resolved = await getLocalizedPosts(locale);
const dateLocale = localeMeta[locale]?.htmlLang ?? locale;

const posts = resolved.map((post) => ({
  url: `/${locale}/blog/${post.slug}`,
  title: post.entry.data.title,
  pubDate: post.entry.data.pubDate,
}));
---

<PageLayout locale={locale}>
  <section class="relative mb-16">
    <h3 class="text-[40px] font-semibold leading-tight text-slate12">
      {slateConfig.title}
    </h3>
    <p class="text-xl text-slate10">{slateConfig.description}</p>
    <Search
      client:only="react"
      className="absolute right-0 top-1/2 -translate-y-1/2"
    />
  </section>

  <section class="mb-16">
    <div class="text-base text-slate12">
      {
        posts.map((item) => (
          <a class="flex cursor-pointer flex-col gap-1 rounded-lg py-2.5 transition-all active:scale-[0.995] active:bg-slate4 sm:flex-row sm:items-baseline sm:justify-between sm:gap-x-6 sm:px-2 sm:hover:bg-slate3" href={item.url} title={item.title}>
            <span class="min-w-0">{item.title}</span>
            <span class="shrink-0 whitespace-nowrap text-slate8">
              {item.pubDate?.toLocaleDateString(dateLocale, {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </span>
          </a>
        ))
      }
    </div>
  </section>
</PageLayout>
